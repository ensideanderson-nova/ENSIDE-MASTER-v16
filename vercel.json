{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "EVOLUTION_API_URL": "https://evolution-api-latest-poc1.onrender.com",
    "EVOLUTION_API_KEY": "23D116F5-A4D3-404F-8D38-66EBF544A44A",
    "EVOLUTION_INSTANCE": "enside"
  }
}
