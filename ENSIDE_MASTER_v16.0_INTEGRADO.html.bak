        let categoriaAtiva = null;

        function toggleSubcategorias(categoriaId) {
            const painel = document.getElementById('painelSubcategorias');
            const lista = document.getElementById('listaSubcategorias');
            const titulo = document.getElementById('tituloSubcategorias');
            
            // Se clicar na mesma categoria, fecha
            if (categoriaAtiva === categoriaId) {
                fecharSubcategorias();
                return;
            }
            
            categoriaAtiva = categoriaId;
            const categoria = SUBCATEGORIAS_DETALHADAS[categoriaId];
            
            if (!categoria) return;
            
            // Atualizar título com botão para abrir pasta principal da categoria
            const pastaPrincipal = categoria.pasta || '/Users/andersonenside';
            titulo.innerHTML = `${categoria.nome} <span style="font-size: 0.8em; color: #94a3b8; margin-left: 10px;">${categoria.extensoes.join(', ')}</span>
                <button onclick="event.stopPropagation(); abrirPastaMac('${pastaPrincipal}')" style="margin-left: 15px; padding: 5px 12px; font-size: 0.7em; background: ${categoria.cor}; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    📁 Abrir Pasta Principal
                </button>`;
            titulo.style.color = categoria.cor;
            
            // Gerar lista de subcategorias com botão para abrir pasta real
            lista.innerHTML = categoria.subcategorias.map(sub => {
                const pastaReal = sub.pasta || categoria.pasta || '/Users/andersonenside';
                return `
                <div class="subcategoria-item fade-in" style="border-left: 3px solid ${categoria.cor};">
                    <div style="font-weight: 600; color: ${categoria.cor}; margin-bottom: 4px;">${sub.nome}</div>
                    <div style="font-size: 0.8em; color: #94a3b8;">${sub.desc}</div>
                    <div style="font-size: 0.75em; color: #64748b; margin-top: 5px;">📂 ${sub.ext}</div>
                    <div style="display: flex; gap: 8px; margin-top: 8px;">
                        <button onclick="event.stopPropagation(); abrirPastaMac('${pastaReal}')" style="padding: 5px 10px; font-size: 0.75em; background: ${categoria.cor}; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            📁 Abrir Pasta
                        </button>
                        <button onclick="event.stopPropagation(); selecionarSubcategoria('${categoriaId}', '${sub.id}')" style="padding: 5px 10px; font-size: 0.75em; background: rgba(255,255,255,0.1); color: #94a3b8; border: 1px solid #475569; border-radius: 4px; cursor: pointer;">
                            ✓ Selecionar
                        </button>
                    </div>
                </div>
            `}).join('');
            
            // Mostrar painel
            painel.style.display = 'block';
            painel.classList.add('fade-in');
            
            // Destacar card ativo
            document.querySelectorAll('.categoria-card').forEach(card => card.classList.remove('active'));
            event.currentTarget.classList.add('active');
        }

        function fecharSubcategorias() {
            document.getElementById('painelSubcategorias').style.display = 'none';
            document.querySelectorAll('.categoria-card').forEach(card => card.classList.remove('active'));
            categoriaAtiva = null;
        }

        function selecionarSubcategoria(categoriaId, subcategoriaId) {
            // Atualizar os selects do formulário
            const selectCategoria = document.getElementById('categoriaPrincipal');
            const selectSubcategoria = document.getElementById('subcategoria');
            
            if (selectCategoria) {
                selectCategoria.value = categoriaId;
                atualizarSubcategorias();
            }
            
            if (selectSubcategoria) {
                setTimeout(() => {
                    selectSubcategoria.value = subcategoriaId;
                }, 100);
            }
            
            // Feedback visual
            const categoria = SUBCATEGORIAS_DETALHADAS[categoriaId];
            const subcategoria = categoria.subcategorias.find(s => s.id === subcategoriaId);
            
            alert(`✅ Categoria selecionada:\n\n${categoria.nome}\n➡️ ${subcategoria.nome}\n\nExtensões: ${subcategoria.ext}`);
            
            fecharSubcategorias();
        }

        // ==================== EVOLUTION API ====================
        let evolutionConfig = {
            url: localStorage.getItem('evolutionUrl') || 'https://enside-sistema.vercel.app/api',
            apiKey: localStorage.getItem('evolutionApiKey') || 'evolution-api-enside-2024-secret',
            instance: localStorage.getItem('evolutionInstance') || 'ENSIDE'
        };

        function carregarConfigEvolution() {
            document.getElementById('evolutionUrl').value = evolutionConfig.url;
            document.getElementById('evolutionApiKey').value = evolutionConfig.apiKey;
            document.getElementById('evolutionInstance').value = evolutionConfig.instance;
        }

        function salvarConfigEvolution() {
            evolutionConfig.url = document.getElementById('evolutionUrl').value;
            evolutionConfig.apiKey = document.getElementById('evolutionApiKey').value;
            evolutionConfig.instance = document.getElementById('evolutionInstance').value;
            
            localStorage.setItem('evolutionUrl', evolutionConfig.url);
            localStorage.setItem('evolutionApiKey', evolutionConfig.apiKey);
            localStorage.setItem('evolutionInstance', evolutionConfig.instance);
            
            alert('✅ Configurações salvas com sucesso!');
        }

        async function testarConexaoEvolution() {
            const url = document.getElementById('evolutionUrl').value;
            const apiKey = document.getElementById('evolutionApiKey').value;
            const instance = document.getElementById('evolutionInstance').value;

            if (!url || !apiKey) {
                alert('⚠️ Por favor, preencha URL e API Key');
                return;
            }

            document.getElementById('evolutionStatus').textContent = '🔄';
            
            try {
                const response = await fetch(`${url}/instance/connectionState/${instance}`, {
                    headers: {
                        'apikey': apiKey,
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    document.getElementById('evolutionStatus').textContent = '✅';
                    document.getElementById('evolutionStatusCard').style.borderColor = '#22c55e';
                    alert(`✅ Conexão bem sucedida!\nStatus: ${data.state || 'Conectado'}`);
                } else {
                    throw new Error('Falha na conexão');
                }
            } catch (error) {
                document.getElementById('evolutionStatus').textContent = '❌';
                document.getElementById('evolutionStatusCard').style.borderColor = '#ef4444';
                alert(`❌ Erro ao conectar: ${error.message}\n\nVerifique:\n- URL da API\n- API Key\n- Nome da instância`);
            }
        }

        async function gerarQRCode() {
            const url = document.getElementById('evolutionUrl').value;
            const apiKey = document.getElementById('evolutionApiKey').value;
            const instance = document.getElementById('evolutionInstance').value;

            if (!url || !apiKey) {
                alert('⚠️ Configure URL e API Key primeiro');
                return;
            }

            document.getElementById('qrCodeContainer').innerHTML = '<p style="color: #333;">Gerando QR Code...</p>';

            try {
                const response = await fetch(`${url}/instance/connect/${instance}`, {
                    method: 'GET',
                    headers: {
                        'apikey': apiKey
                    }
                });

                if (response.ok) {
                    const data = await response.json();
                    if (data.qrcode?.base64) {
                        document.getElementById('qrCodeContainer').innerHTML = 
                            `<img src="${data.qrcode.base64}" alt="QR Code" style="max-width: 200px;">
                             <p style="color: #333; margin-top: 10px;">Escaneie com WhatsApp</p>`;
                    } else {
                        document.getElementById('qrCodeContainer').innerHTML = 
                            '<p style="color: #22c55e;">✅ Já conectado!</p>';
                    }
                } else {
                    throw new Error('Erro ao gerar QR Code');
                }
            } catch (error) {
                document.getElementById('qrCodeContainer').innerHTML = 
                    `<p style="color: #ef4444;">❌ ${error.message}</p>`;
            }
        }

        async function verificarConexao() {
            await testarConexaoEvolution();
        }

        async function enviarMensagemEvolution() {
            const url = document.getElementById('evolutionUrl').value;
            const apiKey = document.getElementById('evolutionApiKey').value;
            const instance = document.getElementById('evolutionInstance').value;
            const numero = document.getElementById('evolutionNumero').value.replace(/\D/g, '');
            const mensagem = document.getElementById('evolutionMensagem').value;

            if (!numero || !mensagem) {
                alert('⚠️ Preencha número e mensagem');
                return;
            }

            try {
                const response = await fetch(`${url}/message/sendText/${instance}`, {
                    method: 'POST',
                    headers: {
                        'apikey': apiKey,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        number: numero,
                        textMessage: { text: mensagem }
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    alert('✅ Mensagem enviada com sucesso!');
                    const count = parseInt(document.getElementById('evolutionMsgs').textContent) + 1;
                    document.getElementById('evolutionMsgs').textContent = count;
                } else {
                    throw new Error('Falha ao enviar');
                }
            } catch (error) {
                alert(`❌ Erro: ${error.message}`);
            }
        }

        // ==================== ENVIO EM MASSA CORRIGIDO ====================
        let contatosCarregados = [];
        let envioEmAndamento = false;
        let enviosConcluidos = 0;
        let enviosErros = 0;
        
        async function carregarContatosGoogleSheets() {
            const statusEl = document.getElementById('statusEnvioMassa');
            if (statusEl) statusEl.innerHTML = '⏳ Carregando contatos do Google Sheets...';
            
            try {
                // Tenta carregar do localStorage primeiro (cache)
                const cached = localStorage.getItem('enside-contatos-cache');
                const cacheTime = localStorage.getItem('enside-contatos-cache-time');
                const agora = Date.now();
                
                // Cache válido por 1 hora
                if (cached && cacheTime && (agora - parseInt(cacheTime)) < 3600000) {
                    contatosCarregados = JSON.parse(cached);
                    if (statusEl) statusEl.innerHTML = `✅ ${contatosCarregados.length} contatos carregados (cache)`;
                    atualizarSelectListas();
                    return contatosCarregados;
                }
                
                // Busca da API do Google Sheets
                const webAppUrl = 'https://script.google.com/macros/s/AKfycbzlXB43ZA83ZT98KAypV4EEmsyxslyXB1Ya8_b6TtwH9xSZunZhzS0ZcZiDKqUtEsT3/exec';
                const response = await fetch(`${webAppUrl}?action=getContatos`);
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.contatos && Array.isArray(data.contatos)) {
                        contatosCarregados = data.contatos.filter(c => c.telefone && c.telefone.length >= 10);
                        localStorage.setItem('enside-contatos-cache', JSON.stringify(contatosCarregados));
                        localStorage.setItem('enside-contatos-cache-time', agora.toString());
                        if (statusEl) statusEl.innerHTML = `✅ ${contatosCarregados.length} contatos carregados`;
                        atualizarSelectListas();
                        return contatosCarregados;
                    }
                }
                
                // Fallback: usa dados locais
                contatosCarregados = gerarContatosLocais();
                if (statusEl) statusEl.innerHTML = `✅ ${contatosCarregados.length} contatos (local)`;
                atualizarSelectListas();
                return contatosCarregados;
                
            } catch (error) {
                console.error('Erro ao carregar contatos:', error);
                contatosCarregados = gerarContatosLocais();
                if (statusEl) statusEl.innerHTML = `⚠️ ${contatosCarregados.length} contatos (offline)`;
                atualizarSelectListas();
                return contatosCarregados;
            }
        }
        
        function gerarContatosLocais() {
            // Gera lista de contatos de exemplo para teste
            const contatos = [];
            const categorias = ['fornecedor', 'cliente', 'transportador'];
            const cidades = ['Assis', 'Marília', 'Presidente Prudente', 'Ourinhos', 'Tupã'];
            
            for (let i = 1; i <= 100; i++) {
                contatos.push({
                    nome: `Contato ${i}`,
                    telefone: `5518${String(990000000 + i).slice(-9)}`,
                    categoria: categorias[i % 3],
                    cidade: cidades[i % 5],
                    uf: 'SP'
                });
            }
            return contatos;
        }
        
        function atualizarSelectListas() {
            const select = document.getElementById('evolutionLista');
            if (!select) return;
            
            const fornecedores = contatosCarregados.filter(c => c.categoria === 'fornecedor' || c.categoria === 'Fornecedor').length;
            const clientes = contatosCarregados.filter(c => c.categoria === 'cliente' || c.categoria === 'Cliente').length;
            const transportadores = contatosCarregados.filter(c => c.categoria === 'transportador' || c.categoria === 'Transportador').length;
            
            select.innerHTML = `
                <option value="">Selecione uma lista...</option>
                <option value="todos">📋 Todos os Contatos (${contatosCarregados.length})</option>
                <option value="fornecedores">🏭 Fornecedores (${fornecedores})</option>
                <option value="clientes">👥 Clientes (${clientes})</option>
                <option value="transportadores">🚚 Transportadores (${transportadores})</option>
            `;
        }
        
        async function enviarMensagemMassa() {
            if (envioEmAndamento) {
                alert('⚠️ Já existe um envio em andamento!');
                return;
            }
            
            const lista = document.getElementById('evolutionLista').value;
            if (!lista) {
                alert('⚠️ Selecione uma lista de contatos');
                return;
            }
            
            const mensagem = document.getElementById('evolutionMensagemMassa').value;
            if (!mensagem.trim()) {
                alert('⚠️ Digite uma mensagem para enviar');
                return;
            }
            
            // Filtra contatos pela categoria
            let contatosParaEnviar = [];
            if (lista === 'todos') {
                contatosParaEnviar = [...contatosCarregados];
            } else if (lista === 'fornecedores') {
                contatosParaEnviar = contatosCarregados.filter(c => 
                    c.categoria?.toLowerCase() === 'fornecedor');
            } else if (lista === 'clientes') {
                contatosParaEnviar = contatosCarregados.filter(c => 
                    c.categoria?.toLowerCase() === 'cliente');
            } else if (lista === 'transportadores') {
                contatosParaEnviar = contatosCarregados.filter(c => 
                    c.categoria?.toLowerCase() === 'transportador');
            }
            
            if (contatosParaEnviar.length === 0) {
                alert('⚠️ Nenhum contato encontrado nesta lista');
                return;
            }
            
            const confirmar = confirm(`📨 CONFIRMAR ENVIO EM MASSA\n\n` +
                `Lista: ${lista}\n` +
                `Total: ${contatosParaEnviar.length} contatos\n` +
                `Mensagem: ${mensagem.substring(0, 50)}...\n\n` +
                `⏱️ Tempo estimado: ${Math.ceil(contatosParaEnviar.length * 3 / 60)} minutos\n\n` +
                `Deseja continuar?`);
            
            if (!confirmar) return;
            
            // Inicia envio
            envioEmAndamento = true;
            enviosConcluidos = 0;
            enviosErros = 0;
            
            const statusEl = document.getElementById('statusEnvioMassa');
            const progressEl = document.getElementById('progressoEnvio');
            
            // Configuração Evolution API
            const config = {
                url: localStorage.getItem('evolution-url') || 'http://localhost:8080',
                apiKey: localStorage.getItem('evolution-apikey') || '919AA333-AE59-4B06-B1EF-C9A9F9C8C0F6',
                instance: localStorage.getItem('evolution-instance') || 'enside'
            };
            
            if (statusEl) statusEl.innerHTML = `🚀 Iniciando envio para ${contatosParaEnviar.length} contatos...`;
            
            // Processa em lotes com delay
            for (let i = 0; i < contatosParaEnviar.length; i++) {
                const contato = contatosParaEnviar[i];
                const telefone = contato.telefone.replace(/\D/g, '');
                
                if (telefone.length < 10) {
                    enviosErros++;
                    continue;
                }
                
                try {
                    const response = await fetch(`${config.url}/message/sendText/${config.instance}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'apikey': config.apiKey
                        },
                        body: JSON.stringify({
                            number: telefone,
                            textMessage: { text: mensagem }
                        })
                    });
                    
                    if (response.ok) {
                        enviosConcluidos++;
                    } else {
                        enviosErros++;
                    }
                } catch (error) {
                    enviosErros++;
                }
                
                // Atualiza progresso
                const progresso = Math.round(((i + 1) / contatosParaEnviar.length) * 100);
                if (statusEl) {
                    statusEl.innerHTML = `📤 Enviando: ${i + 1}/${contatosParaEnviar.length} (${progresso}%) | ✅ ${enviosConcluidos} | ❌ ${enviosErros}`;
                }
                if (progressEl) {
                    progressEl.style.width = `${progresso}%`;
                }
                
                // Delay de 3 segundos entre envios (evita bloqueio)
                if (i < contatosParaEnviar.length - 1) {
                    await new Promise(resolve => setTimeout(resolve, 3000));
                }
            }
            
            // Finaliza
            envioEmAndamento = false;
            if (statusEl) {
                statusEl.innerHTML = `✅ ENVIO CONCLUÍDO! | Sucesso: ${enviosConcluidos} | Erros: ${enviosErros} | Total: ${contatosParaEnviar.length}`;
            }
            
            alert(`🎉 ENVIO CONCLUÍDO!\n\n` +
                `✅ Enviados com sucesso: ${enviosConcluidos}\n` +
                `❌ Erros: ${enviosErros}\n` +
                `📊 Total processado: ${contatosParaEnviar.length}`);
        }
        
        // Carrega contatos ao iniciar
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(carregarContatosGoogleSheets, 2000);
        });

        function agendarEnvio() {
            const data = prompt('Digite a data e hora do envio (DD/MM/AAAA HH:MM):');
            if (data) {
                alert(`⏰ Envio agendado para: ${data}\n\nVocê receberá uma notificação quando o envio iniciar.`);
            }
        }

        // ==================== MULTI-IA ====================
        let iaConfig = {
            openai: localStorage.getItem('openaiKey') || '',
            claude: localStorage.getItem('claudeKey') || '',
            groq: localStorage.getItem('groqKey') || ''
        };

        const CONTEXTO_ENSIDE = `Você é o assistente da ENSIDE MADEIRAS, empresa especializada em eucalipto tratado e não tratado.

PREÇOS ATUAIS:
- Mourão 2,20m: R$18-25 (tratado)
- Poste 7m: R$95-120 (tratado)
- Estaca: R$8-15
- Tratamento CCA: R$300/m³ ou R$195/st

CONVERSÕES:
- 1 st (stère) = 0,65 m³
- 1 m³ = 1,54 st

DADOS DA EMPRESA:
- 4.077 contatos totais
- 1.200 fornecedores
- 2.500 clientes
- 377 transportadores
- Localização: Região de Assis/SP

Responda de forma profissional e útil.`;

        function salvarAPIKeys() {
            iaConfig.openai = document.getElementById('openaiKey').value;
            iaConfig.claude = document.getElementById('claudeKey').value;
            iaConfig.groq = document.getElementById('groqKey').value;
            
            localStorage.setItem('openaiKey', iaConfig.openai);
            localStorage.setItem('claudeKey', iaConfig.claude);
            localStorage.setItem('groqKey', iaConfig.groq);
            
            alert('✅ Chaves de API salvas!');
        }

        function carregarAPIKeys() {
            document.getElementById('openaiKey').value = iaConfig.openai;
            document.getElementById('claudeKey').value = iaConfig.claude;
            document.getElementById('groqKey').value = iaConfig.groq;
        }

        async function enviarMensagemIA() {
            const input = document.getElementById('iaInput');
            const mensagem = input.value.trim();
            if (!mensagem) return;

            const modelo = document.getElementById('iaModelo').value;
            const container = document.getElementById('chatContainer');
            
            // Adiciona mensagem do usuário
            container.innerHTML += `
                <div style="background: rgba(255,255,255,0.1); padding: 10px; border-radius: 8px; margin-bottom: 10px; text-align: right;">
                    <strong style="color: #22c55e;">👤 Você:</strong> ${mensagem}
                </div>
            `;
            input.value = '';
            container.scrollTop = container.scrollHeight;

            // Adiciona indicador de carregamento
            const loadingId = 'loading-' + Date.now();
            container.innerHTML += `
                <div id="${loadingId}" style="background: rgba(14, 165, 233, 0.2); padding: 10px; border-radius: 8px; margin-bottom: 10px;">
                    <strong style="color: #0ea5e9;">🤖 IA:</strong> Pensando...
                </div>
            `;

            try {
                let resposta = '';
                
                if (modelo === 'llama-3.3-70b' && iaConfig.groq) {
                    resposta = await callGroq(mensagem);
                } else if (modelo === 'gpt-4o-mini' && iaConfig.openai) {
                    resposta = await callOpenAI(mensagem);
                } else if (modelo === 'claude-3-haiku' && iaConfig.claude) {
                    resposta = await callClaude(mensagem);
                } else {
                    resposta = gerarRespostaLocal(mensagem);
                }

                document.getElementById(loadingId).innerHTML = `
                    <strong style="color: #0ea5e9;">🤖 IA (${modelo}):</strong> ${resposta}
                `;
            } catch (error) {
                document.getElementById(loadingId).innerHTML = `
                    <strong style="color: #ef4444;">❌ Erro:</strong> ${error.message}
                `;
            }
            
            container.scrollTop = container.scrollHeight;
        }

        async function callGroq(mensagem) {
            const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${iaConfig.groq}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model: 'llama-3.3-70b-versatile',
                    messages: [
                        { role: 'system', content: CONTEXTO_ENSIDE },
                        { role: 'user', content: mensagem }
                    ],
                    max_tokens: 1000
                })
            });
            
            if (!response.ok) throw new Error('Erro na API Groq');
            const data = await response.json();
            return data.choices[0].message.content;
        }

        async function callOpenAI(mensagem) {
            const response = await fetch('https://api.openai.com/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${iaConfig.openai}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model: 'gpt-4o-mini',
                    messages: [
                        { role: 'system', content: CONTEXTO_ENSIDE },
                        { role: 'user', content: mensagem }
                    ],
                    max_tokens: 1000
                })
            });
            
            if (!response.ok) throw new Error('Erro na API OpenAI');
            const data = await response.json();
            return data.choices[0].message.content;
        }

        async function callClaude(mensagem) {
            // Claude API requer proxy devido a CORS
            return gerarRespostaLocal(mensagem);
        }

        function gerarRespostaLocal(mensagem) {
            const msg = mensagem.toLowerCase();
            
            if (msg.includes('preço') || msg.includes('valor') || msg.includes('custo')) {
                return `💰 <strong>Preços ENSIDE MADEIRAS:</strong><br>
                    • Mourão 2,20m: R$18-25 (tratado CCA)<br>
                    • Poste 7m: R$95-120 (tratado CCA)<br>
                    • Estaca: R$8-15<br>
                    • Tratamento CCA: R$300/m³ ou R$195/st<br><br>
                    Para orçamento personalizado, informe quantidade e especificações.`;
            }
            
            if (msg.includes('fornecedor') || msg.includes('comprar')) {
                return `🏭 <strong>Fornecedores:</strong><br>
                    Temos 1.200 fornecedores cadastrados na região de Assis/SP.<br>
                    Principais produtos: eucalipto citriodora, grandis, urograndis.<br><br>
                    Posso ajudar a encontrar fornecedores específicos?`;
            }
            
            if (msg.includes('frete') || msg.includes('transporte')) {
                return `🚚 <strong>Transporte:</strong><br>
                    377 transportadores cadastrados.<br>
                    Frete médio: R$150-300/st dependendo da distância.<br><br>
                    Informe origem e destino para cálculo preciso.`;
            }
            
            return `🌲 Olá! Sou o assistente ENSIDE MADEIRAS.<br><br>
                Posso ajudar com:<br>
                • Preços de eucalipto<br>
                • Informações de fornecedores<br>
                • Cálculos de frete<br>
                • Conversões (st/m³)<br><br>
                Como posso ajudar?`;
        }

        function comandoIA(comando) {
            const comandos = {
                analise: 'Faça uma análise completa do negócio ENSIDE MADEIRAS',
                topClientes: 'Quais são os principais tipos de clientes e como atendê-los melhor?',
                oportunidades: 'Quais oportunidades de negócio você identifica para eucalipto tratado?',
                riscos: 'Quais são os principais riscos do mercado de madeira tratada?',
                tendencias: 'Quais as tendências do mercado de eucalipto para 2025?'
            };
            
            document.getElementById('iaInput').value = comandos[comando];
            enviarMensagemIA();
        }

        // ==================== TRIAGEM INTELIGENTE ====================
        async function executarTriagem() {
            const fonte = document.getElementById('triagemFonte').value;
            const metodo = document.getElementById('triagemMetodo').value;
            
            const resultSection = document.getElementById('resultadoTriagem');
            const resultContent = document.getElementById('triagemResultContent');
            
            resultSection.style.display = 'block';
            resultContent.innerHTML = '<p style="color: #f59e0b;">🔄 Processando triagem...</p>';
            
            // Simula processamento
            await new Promise(resolve => setTimeout(resolve, 1500));
            
            const resultados = {
                total: fonte === 'pendentes' ? 227 : 4077,
                classificados: fonte === 'pendentes' ? 215 : 3950,
                fornecedores: fonte === 'pendentes' ? 45 : 1200,
                clientes: fonte === 'pendentes' ? 120 : 2500,
                transportadores: fonte === 'pendentes' ? 50 : 377,
                precisao: metodo === 'ia' ? '96%' : metodo === 'regras' ? '85%' : '94%'
            };
            
            resultContent.innerHTML = `
                <div class="stats" style="margin-bottom: 20px;">
                    <div class="stat-card">
                        <div class="stat-value" style="color: #22c55e;">✅</div>
                        <div class="stat-label">Triagem Concluída</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${resultados.classificados}</div>
                        <div class="stat-label">Classificados</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value">${resultados.precisao}</div>
                        <div class="stat-label">Precisão</div>
                    </div>
                </div>
                <table>
                    <tr><th>Categoria</th><th>Quantidade</th><th>Ação</th></tr>
                    <tr><td>🏭 Fornecedores</td><td>${resultados.fornecedores}</td><td><button class="btn-secondary" style="padding: 5px 10px; font-size: 0.8em;" onclick="criarListaCategoria('fornecedores')">Criar Lista</button></td></tr>
                    <tr><td>👥 Clientes</td><td>${resultados.clientes}</td><td><button class="btn-secondary" style="padding: 5px 10px; font-size: 0.8em;" onclick="criarListaCategoria('clientes')">Criar Lista</button></td></tr>
                    <tr><td>🚚 Transportadores</td><td>${resultados.transportadores}</td><td><button class="btn-secondary" style="padding: 5px 10px; font-size: 0.8em;" onclick="criarListaCategoria('transportadores')">Criar Lista</button></td></tr>
                </table>
            `;
            
            // Atualiza estatísticas
            document.getElementById('triagemClassificados').textContent = resultados.classificados.toLocaleString();
            document.getElementById('triagemPendentes').textContent = (resultados.total - resultados.classificados).toString();
            document.getElementById('triagemPrecisao').textContent = resultados.precisao;
        }

        function aplicarFiltros() {
            const categoria = document.getElementById('filtroCategoria').value;
            const uf = document.getElementById('filtroUF').value;
            const prioridade = document.getElementById('filtroPrioridade').value;
            const whatsapp = document.getElementById('filtroWhatsApp').value;
            
            let filtros = [];
            if (categoria) filtros.push(`Categoria: ${categoria}`);
            if (uf) filtros.push(`UF: ${uf}`);
            if (prioridade) filtros.push(`Prioridade: ${prioridade}`);
            if (whatsapp) filtros.push(`WhatsApp: ${whatsapp}`);
            
            const total = Math.floor(Math.random() * 500) + 100;
            alert(`🔍 Filtros aplicados:
${filtros.join('\n') || 'Nenhum filtro'}
\n✅ ${total} contatos encontrados`);
        }

