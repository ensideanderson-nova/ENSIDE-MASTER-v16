            </div>
            <div style="margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap;">
                <button onclick="executarComandoRapido('ESPECIALISTA_IA.gerarRelatorio()')" class="btn" style="background: rgba(34,197,94,0.2); border: 1px solid #22c55e; font-size: 0.85em;">📋 Relatório</button>
                <button onclick="executarComandoRapido('ESPECIALISTA_IA.verificarStatus()')" class="btn" style="background: rgba(14,165,233,0.2); border: 1px solid #0ea5e9; font-size: 0.85em;">📊 Status</button>
                <button onclick="executarComandoRapido('ESPECIALISTA_IA.ajuda()')" class="btn" style="background: rgba(245,158,11,0.2); border: 1px solid #f59e0b; font-size: 0.85em;">❓ Ajuda</button>
                <button onclick="executarComandoRapido('ESPECIALISTA_IA.conhecimentos.apis')" class="btn" style="background: rgba(168,85,247,0.2); border: 1px solid #a855f7; font-size: 0.85em;">🔗 APIs</button>
